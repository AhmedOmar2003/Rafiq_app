# -----------------------------------------------------------------------------
# Rafiq Flutter app staging build-time env sample
# Use `--dart-define-from-file=.env.staging` for staging APKs only.
# -----------------------------------------------------------------------------

SUPABASE_URL=https://your-staging-project.supabase.co
SUPABASE_ANON_KEY=replace-with-staging-anon-key
SUPABASE_RECOVERY_REDIRECT_URL=rafiqapp-staging://reset-password

GOOGLE_WEB_CLIENT_ID=replace-with-staging-google-web-client-id.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=replace-with-staging-google-ios-client-id.apps.googleusercontent.com
GOOGLE_WEB_OAUTH_REDIRECT_URL=https://staging-dashboard.rafiq.com/app/

FLUTTER_APP_SCHEME=rafiqapp-staging
SENTRY_DSN=replace-with-staging-sentry-dsn
