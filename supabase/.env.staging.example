# -----------------------------------------------------------------------------
# Supabase staging CLI / Edge Function secrets sample
# Never commit real values.
# -----------------------------------------------------------------------------

SUPABASE_ACCESS_TOKEN=replace-with-supabase-access-token
SUPABASE_DB_PASSWORD=replace-with-staging-postgres-password

SUPABASE_URL=https://your-staging-project.supabase.co
SUPABASE_ANON_KEY=replace-with-staging-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-staging-service-role-key
GEMINI_API_KEY=replace-with-staging-gemini-api-key
ALLOWED_ORIGINS=http://localhost:3000,https://staging-dashboard.rafiq.com

GOOGLE_CLIENT_ID=replace-with-staging-google-oauth-client-id
GOOGLE_CLIENT_SECRET=replace-with-staging-google-oauth-client-secret
